<header class="page-header">
  <div>
    <span class="eyebrow">Operations</span>
    <h1>Tenants</h1>
  </div>
</header>

<p class="text-light"><small>Applicants with at least one lease. Tenants are created automatically when a lease is created for an applicant.</small></p>

<div class="filter-bar">
  <span class="scope">
    <% if @show_inactive %>
      <%= link_to "Active", tenants_path %>
      <strong>Inactive</strong>
    <% else %>
      <strong>Active</strong>
      <%= link_to "Inactive", tenants_path(inactive: 1) %>
    <% end %>
  </span>
</div>

<% if @result.tenants.empty? %>
  <p class="empty">No tenants yet.</p>
<% else %>
  <div class="table">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Mobile</th>
          <th>Current lease</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @result.tenants.each do |t| %>
          <tr>
            <td><%= link_to t.name, tenant_path(t.id) %></td>
            <td><% if t.mobile %><%= link_to t.mobile, "tel:#{t.mobile}" %><% end %></td>
            <td><%= safe_join(t.current_leases.map { |l| link_to l.name, lease_path(l.id) }, tag.br) %></td>
            <td>
              <% if t.active? %>
                <span class="badge" data-variant="success">Active</span>
              <% else %>
                <span class="badge" data-variant="secondary">Inactive</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
