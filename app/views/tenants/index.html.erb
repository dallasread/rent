<h1>Tenants</h1>

<p><small>Applicants with at least one lease. Tenants are created automatically when a lease is created for an applicant.</small></p>

<% if @result.tenants.empty? %>
  <p>No tenants yet.</p>
<% else %>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Mobile</th>
        <th>Properties</th>
      </tr>
    </thead>
    <tbody>
      <% @result.tenants.each do |t| %>
        <tr>
          <td><%= link_to t.name, tenant_path(t.id) %></td>
          <td><% if t.mobile %><%= link_to t.mobile, "tel:#{t.mobile}" %><% end %></td>
          <td><%= safe_join(t.property_ids.map { |pid| property_link(pid) }, tag.br) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
