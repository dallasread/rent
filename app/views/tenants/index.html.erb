<header class="page-header">
  <div>
    <span class="eyebrow">Listings</span>
    <h1>Tenants</h1>
  </div>
</header>

<p class="text-light"><small>Applicants with at least one lease. Tenants are created automatically when a lease is created for an applicant.</small></p>

<div class="filter-bar">
  <% if @show_inactive %>
    <span class="scope"><strong>Active &amp; inactive</strong></span>
    <%= link_to "Hide inactive", tenants_path, class: "toggle" %>
  <% else %>
    <span class="scope"><strong>Active</strong></span>
    <%= link_to "Show inactive", tenants_path(inactive: 1), class: "toggle" %>
  <% end %>
</div>

<% if @result.tenants.empty? %>
  <p class="empty">No tenants yet.</p>
<% else %>
  <div class="table">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Mobile</th>
          <th>Properties</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @result.tenants.each do |t| %>
          <tr>
            <td><%= link_to t.name, tenant_path(t.id) %></td>
            <td><% if t.mobile %><%= link_to t.mobile, "tel:#{t.mobile}" %><% end %></td>
            <td><%= safe_join(t.property_ids.map { |pid| property_link(pid) }, tag.br) %></td>
            <td>
              <% if t.active? %>
                <span class="badge" data-variant="success">Active</span>
              <% else %>
                <span class="badge" data-variant="secondary">Inactive</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
