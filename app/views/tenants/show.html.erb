<%= breadcrumbs(
  [ "Tenants", tenants_path ],
  [ @tenant.name ]
) %>

<header class="page-header">
  <div>
    <span class="eyebrow">Tenant</span>
    <h1><%= @tenant.name %></h1>
  </div>
  <div class="toolbar">
    <%= link_to "View application", applicant_path(@tenant.applicant_id), class: "button ghost" %>
  </div>
</header>

<section class="card">
  <dl class="kv">
    <dt>Mobile</dt>
    <dd><%= link_to @tenant.mobile, "tel:#{@tenant.mobile}" %></dd>
  </dl>
</section>

<header class="section-head">
  <h2>Leases</h2>
</header>

<div class="table">
  <table>
    <thead>
      <tr>
        <th>Property</th>
        <th>Lease</th>
      </tr>
    </thead>
    <tbody>
      <% @tenant.leases.each do |l| %>
        <tr>
          <td><%= property_link(l.property_id) %></td>
          <td><%= link_to l.name, lease_path(l.id) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
