<header class="page-header">
  <div>
    <span class="eyebrow">System</span>
    <h1>Audit log</h1>
  </div>
</header>

<section class="card mb-6">
  <%= form_with url: audit_path, method: :get, local: true, class: "filter-form-row" do |f| %>
    <div data-field>
      <label for="entity_id">Entity ID</label>
      <%= f.text_field :entity_id, value: params[:entity_id], id: "entity_id", placeholder: "property_id, lease_id, tx_id, …" %>
    </div>
    <div data-field>
      <label for="actor">Actor (mobile)</label>
      <%= f.text_field :actor, value: params[:actor], id: "actor", placeholder: "+15551234567" %>
    </div>
    <div data-field>
      <label for="event_type">Event type</label>
      <%= f.select :event_type, @result.event_types, { include_blank: "— All types —", selected: params[:event_type] }, id: "event_type" %>
    </div>
    <div class="toolbar">
      <%= f.submit "Filter" %>
      <%= link_to "Reset", audit_path, class: "button ghost" %>
    </div>
  <% end %>
</section>

<% if @result.entries.empty? %>
  <p class="empty">No matching events.</p>
<% else %>
  <div class="table">
    <table>
      <thead>
        <tr>
          <th>When</th>
          <th>Type</th>
          <th>Actor</th>
          <th>What</th>
        </tr>
      </thead>
      <tbody>
        <% @result.entries.each do |e| %>
          <tr>
            <td><%= datetime_with_tooltip(e.occurred_at) %></td>
            <td><code><%= e.event_type %></code></td>
            <td>
              <% if e.actor == "system" %>
                system
              <% else %>
                <%= link_to e.actor, audit_path(actor: e.actor) %>
              <% end %>
            </td>
            <td>
              <%= audit_summary(e) %>
              <% details = audit_details(e) %>
              <% if details.any? %>
                <details class="inline">
                  <summary><small>details</small></summary>
                  <dl>
                    <% details.each do |k, v| %>
                      <dt><small><%= k %></small></dt>
                      <dd><small><%= audit_value(k, v) %></small></dd>
                    <% end %>
                  </dl>
                </details>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <nav class="toolbar mt-4" aria-label="Pagination">
    <span class="text-light"><small>Page <%= @result.page %></small></span>
    <% if @result.page > 1 %>
      <%= link_to "← Newer", audit_path(request.query_parameters.merge(page: @result.page - 1)) %>
    <% end %>
    <% if @result.has_next? %>
      <%= link_to "Older →", audit_path(request.query_parameters.merge(page: @result.page + 1)) %>
    <% end %>
  </nav>
<% end %>
