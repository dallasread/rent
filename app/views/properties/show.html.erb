<%
  og_title       = @property.name
  og_description = @property.description.to_s.gsub(/<[^>]+>/, "").strip.truncate(200).presence ||
                   "#{@property.beds} bed / #{@property.baths} bath rental"
  og_url         = property_public_url(@property.slug)
  og_photo       = @property.photos.find { |p| p.blob }
  og_image_url   = og_photo ? url_for(og_photo.variant(:hero)) : nil
%>

<% content_for :title, og_title %>
<% content_for :head do %>
  <meta property="og:type"        content="website">
  <meta property="og:title"       content="<%= og_title %>">
  <meta property="og:description" content="<%= og_description %>">
  <meta property="og:url"         content="<%= og_url %>">
  <meta property="og:site_name"   content="<%= Settings.call.brand_name %>">
  <% if og_image_url %>
    <meta property="og:image"     content="<%= og_image_url %>">
  <% end %>
  <meta name="twitter:card"        content="<%= og_image_url ? 'summary_large_image' : 'summary' %>">
  <meta name="twitter:title"       content="<%= og_title %>">
  <meta name="twitter:description" content="<%= og_description %>">
  <% if og_image_url %>
    <meta name="twitter:image"     content="<%= og_image_url %>">
  <% end %>
  <meta name="description"         content="<%= og_description %>">
<% end %>

<% if admin? %>
  <%= breadcrumbs(
    [ "Properties", properties_path ],
    [ property_admin_label(@property) ]
  ) %>
<% end %>

<header class="page-header">
  <div>
    <% if admin? %>
      <span class="eyebrow">Property<% if @property.address.present? %> · <%= @property.address %><% end %></span>
    <% end %>
    <h1>
      <%= @property.name %>
      <% if admin? %>
        <% if @property.published %>
          <span class="badge" data-variant="success">Accepting applications</span>
        <% else %>
          <span class="badge" data-variant="secondary">Draft</span>
        <% end %>
      <% end %>
    </h1>
  </div>
  <% if authenticated? %>
    <div class="toolbar">
      <%= link_to "Edit this property", edit_property_path(@property.id), class: "button outline" %>
      <%= link_to "History", audit_path(entity_id: @property.id), class: "button ghost" %>
    </div>
  <% end %>
</header>

<% if @property.photos.any? %>
  <div class="photo-carousel" data-controller="carousel">
    <div class="photo-carousel-track" data-carousel-target="track">
      <% @property.photos.each_with_index do |photo, i| %>
        <% next unless photo.blob %>
        <figure class="photo-carousel-slide">
          <%= image_tag photo.variant(:medium), loading: (i.zero? ? "eager" : "lazy"), alt: "#{@property.name} photo #{i + 1}" %>
        </figure>
      <% end %>
    </div>
    <% if @property.photos.size > 1 %>
      <button type="button" class="photo-carousel-nav prev" data-action="carousel#prev" aria-label="Previous photo">‹</button>
      <button type="button" class="photo-carousel-nav next" data-action="carousel#next" aria-label="Next photo">›</button>
    <% end %>
  </div>
<% end %>

<p><strong><%= @property.beds %></strong> bed / <strong><%= @property.baths %></strong> bath</p>

<% if @property.description.present? %>
  <div class="prose">
    <%= sanitize @property.description, tags: %w[p br strong em a ul ol li blockquote h1 h2 h3 h4 div pre code], attributes: %w[href target rel] %>
  </div>
<% end %>

<% if @property.published %>
  <p class="mt-4"><%= button_to "Apply for this property", apply_property_path(@property.slug), method: :get %></p>
<% end %>
