<h1>Properties</h1>

<p><%= link_to "Add property", new_property_path %></p>

<% if @result.properties.empty? %>
  <p>No properties yet.</p>
<% else %>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Beds</th>
        <th>Baths</th>
        <th>Public link</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @result.properties.each do |p| %>
        <tr>
          <td><%= p.name %></td>
          <td><%= p.beds %></td>
          <td><%= p.baths %></td>
          <td><%= link_to p.slug, property_path(p.slug) %></td>
          <td>
            <%= link_to "Edit", edit_property_path(p.slug) %>
            <%= button_to "Duplicate", duplicate_property_path(p.slug), method: :post, form: { style: "display:inline" } %>
            <%= button_to "Delete", property_path(p.slug), method: :delete, form: { style: "display:inline", data: { turbo_confirm: "Delete #{p.name}?" } } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
