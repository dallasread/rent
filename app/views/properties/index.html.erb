<header class="page-header">
  <div>
    <span class="eyebrow">Listings</span>
    <h1>Properties</h1>
  </div>
  <div class="toolbar">
    <%= link_to "Add property", new_property_path, class: "button" %>
  </div>
</header>

<% if @result.properties.empty? %>
  <p class="empty">No properties yet. Add one to start accepting applications.</p>
<% else %>
  <%
    today = Date.current
    leases_by_property = Leases.call.leases.group_by(&:property_id)
  %>
  <div class="table">
    <table>
      <thead>
        <tr>
          <th>Address</th>
          <th>Status</th>
          <th>Current lease</th>
          <th class="num">Beds</th>
          <th class="num">Baths</th>
          <th>Public link</th>
          <th class="actions">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @result.properties.each do |p| %>
          <% current = leases_by_property[p.id]&.find { |l| l.active_on?(today) } %>
          <tr>
            <td><%= link_to property_admin_label(p), property_public_path(p.slug) %></td>
            <td>
              <% if p.published %>
                <span class="badge" data-variant="success">Accepting applications</span>
              <% else %>
                <span class="badge" data-variant="secondary">Draft</span>
              <% end %>
            </td>
            <td>
              <% if current %>
                <%= link_to current.name, lease_path(current.id) %>
              <% else %>
                <span class="text-light">—</span>
              <% end %>
            </td>
            <td class="num"><%= p.beds %></td>
            <td class="num"><%= p.baths %></td>
            <td><%= link_to p.slug, property_public_path(p.slug) %></td>
            <td class="actions">
              <div class="toolbar small">
                <%= button_to "Edit", edit_property_path(p.id), method: :get, class: "outline small" %>
                <% if p.published %>
                  <%= button_to "Unpublish", unpublish_property_path(p.id), method: :post, class: "outline small" %>
                <% else %>
                  <%= button_to "Publish", publish_property_path(p.id), method: :post, class: "outline small" %>
                <% end %>
                <%= button_to "Duplicate", duplicate_property_path(p.id), method: :post, class: "outline small" %>
                <%= button_to "Delete", property_path(p.id), method: :delete, class: "outline small", data: { variant: "danger", turbo_confirm: "Delete #{p.name}?" } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
