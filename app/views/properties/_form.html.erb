<%= form_with url: url, method: method do |f| %>
  <p>
    <label for="name">Public name</label>
    <%= f.text_field :name, value: form.name, id: "name", required: true, autofocus: true %>
    <small>Marketing label shown to non-logged-in visitors (e.g. "Charming Beachfront Cottage").</small>
  </p>

  <p>
    <label for="address">Address</label>
    <%= f.text_field :address, value: form.address, id: "address" %>
    <small>Internal label shown to logged-in users (e.g. "22 Lisgar Street").</small>
  </p>

  <% if form.respond_to?(:slug) && form.slug.present? %>
    <p>
      <label for="permalink">Permalink</label>
      <%= f.text_field :permalink, value: form.slug, id: "permalink" %>
      <small>Used in the public URL. Lowercase letters, numbers, and hyphens. Leave blank to derive from the name.</small>
    </p>
  <% end %>

  <p>
    <label for="beds">Beds</label>
    <%= f.number_field :beds, value: form.beds, id: "beds", min: 0, step: 1 %>
  </p>

  <p>
    <label for="baths">Baths</label>
    <%= f.number_field :baths, value: form.baths, id: "baths", min: 0, step: 1 %>
  </p>

  <p>
    <label for="description-input">Description</label>
    <input type="hidden" name="description" id="description-input" value="<%= form.description %>">
    <trix-editor input="description-input"></trix-editor>
  </p>

  <%= f.submit submit_label %>
  <%= link_to "Cancel", properties_path %>
<% end %>
