<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || Settings.call.brand_name %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= Settings.call.brand_name %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Public+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap">

    <% _settings = Settings.call %>
    <style><%= Rails.application.assets.load_path.find("oat.css")&.content&.html_safe %></style>
    <%= stylesheet_link_tag "trix", "application", "data-turbo-track": "reload" %>
    <% _scheme = color_scheme_for(_settings.background_color) %>
    <style>
      :root {
        color-scheme: <%= _scheme %>;
        --primary:    <%= _settings.primary_color %>;
        --background: <%= _settings.background_color %>;
        --foreground: <%= _settings.text_color %>;
        <% if _scheme == "dark" %>
        --accent:    #27272a;
        --secondary: #27272a;
        --muted:     #27272a;
        --border:    #3f3f46;
        --faint:     #1e1e21;
        --trix-icon-filter: invert(1);
        <% else %>
        --accent:    #f4f4f5;
        --secondary: #f4f4f5;
        --muted:     #f4f4f5;
        --border:    #d4d4d8;
        --faint:     #fafafa;
        --trix-icon-filter: none;
        <% end %>
      }
    </style>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="<%= "sidebar" if authenticated? %>">
    <% if authenticated? %>
      <div data-sidebar-layout>
        <header class="topbar">
          <button type="button" data-sidebar-toggle data-action="sidebar#toggle" aria-label="Menu">☰</button>
          <h1 class="brand"><%= link_to _settings.brand_name, properties_path %></h1>
          <div class="topbar-right">
            <span><%= current_user.mobile %></span>
          </div>
        </header>

        <aside data-sidebar>
          <nav>
            <% if admin? %>
              <ul>
                <li><%= link_to "Properties",   properties_path,   "aria-current": (current_page?(properties_path)   ? "page" : nil) %></li>
                <li><%= link_to "Applicants",   applicants_path,   "aria-current": (current_page?(applicants_path)   ? "page" : nil) %></li>
                <li><%= link_to "Tenants",      tenants_path,      "aria-current": (current_page?(tenants_path)      ? "page" : nil) %></li>
                <li><%= link_to "Leases",       leases_path,       "aria-current": (current_page?(leases_path)       ? "page" : nil) %></li>
                <li><%= link_to "Transactions", transactions_path, "aria-current": (current_page?(transactions_path) ? "page" : nil) %></li>
              </ul>
              <span class="nav-group">System</span>
              <ul>
                <li><%= link_to "Taxes",      taxes_path,      "aria-current": (current_page?(taxes_path)      ? "page" : nil) %></li>
                <li><%= link_to "API tokens", api_tokens_path, "aria-current": (current_page?(api_tokens_path) ? "page" : nil) %></li>
                <li><%= link_to "Audit log",  audit_path,      "aria-current": (current_page?(audit_path)      ? "page" : nil) %></li>
                <li><%= link_to "Settings",   settings_path,   "aria-current": (current_page?(settings_path)   ? "page" : nil) %></li>
              </ul>
            <% end %>
          </nav>
          <footer>
            <%= button_to "Log out", logout_path, method: :delete, class: "outline w-100" %>
          </footer>
        </aside>

        <main>
          <div style="padding: var(--space-3)">
            <% if flash[:notice] %><p class="flash flash-notice"><%= flash[:notice] %></p><% end %>
            <% if flash[:alert] %><p class="flash flash-alert"><%= flash[:alert] %></p><% end %>
            <%= yield %>
          </div>
        </main>
      </div>
    <% else %>
      <main class="public-shell">
        <% if flash[:notice] %><p class="flash flash-notice"><%= flash[:notice] %></p><% end %>
        <% if flash[:alert] %><p class="flash flash-alert"><%= flash[:alert] %></p><% end %>
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
