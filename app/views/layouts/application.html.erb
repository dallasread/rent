<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Rent" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Rent">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "oat", "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if authenticated? %>
      <header class="topbar">
        <h1><%= link_to "Rent", dashboard_path, style: "text-decoration: none; color: inherit;" %></h1>
        <div class="topbar-right">
          <span><%= current_user.mobile %></span>
        </div>
      </header>

      <div data-sidebar-layout>
        <aside data-sidebar>
          <nav>
            <ul>
              <li><%= link_to "Dashboard",  dashboard_path,  "aria-current": (current_page?(dashboard_path)  ? "page" : nil) %></li>
              <% if admin? %>
                <li><%= link_to "Properties", properties_path, "aria-current": (current_page?(properties_path) ? "page" : nil) %></li>
                <li><%= link_to "Applicants", applicants_path, "aria-current": (current_page?(applicants_path) ? "page" : nil) %></li>
                <li><%= link_to "Leases",       leases_path,       "aria-current": (current_page?(leases_path)       ? "page" : nil) %></li>
                <li><%= link_to "Transactions", transactions_path, "aria-current": (current_page?(transactions_path) ? "page" : nil) %></li>
              <% end %>
            </ul>
          </nav>
          <footer>
            <%= button_to "Log out", logout_path, method: :delete, class: "outline", style: "width: 100%;" %>
          </footer>
        </aside>

        <main>
          <div style="padding: var(--space-3)">
            <% if flash[:notice] %><p class="flash flash-notice"><%= flash[:notice] %></p><% end %>
            <% if flash[:alert] %><p class="flash flash-alert"><%= flash[:alert] %></p><% end %>
            <%= yield %>
          </div>
        </main>
      </div>
    <% else %>
      <main class="public-shell">
        <% if flash[:notice] %><p class="flash flash-notice"><%= flash[:notice] %></p><% end %>
        <% if flash[:alert] %><p class="flash flash-alert"><%= flash[:alert] %></p><% end %>
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
