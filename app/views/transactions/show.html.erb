<%
  property  = @lease ? Property.call(property_id: @lease.property_id).property : nil
  applicant = @lease ? Applicant.call(applicant_id: @lease.applicant_id).application : nil
%>

<div class="no-print">
  <%= breadcrumbs(
    [ "Properties", properties_path ],
    property  ? [ property_admin_label(property),  property_path(property.slug) ] : [ "(deleted property)" ],
    applicant ? [ applicant.name,                 applicant_path(applicant.id) ] : [ "(deleted applicant)" ],
    @lease    ? [ @lease.name, lease_path(@lease.id) ] : [ "(deleted lease)" ],
    [ @transaction.description ]
  ) %>
</div>

<div class="receipt">
  <header>
    <h1>Receipt</h1>
    <p><small>Transaction <%= @transaction.id %></small></p>
  </header>

  <p><strong>Status:</strong> <%= transaction_status_label(@transaction) %></p>
  <p><strong>Description:</strong> <%= @transaction.description %></p>
  <p><strong>Amount:</strong> <%= format_money_cents(@transaction.amount_cents) %></p>
  <p><strong>Method:</strong> <%= @transaction.method.presence || "—" %></p>

  <% if @transaction.paid? %>
    <p><strong>Paid on:</strong> <%= @transaction.paid_at.to_date %></p>
  <% end %>

  <p><strong>Recorded:</strong> <%= @transaction.recorded_at.to_fs(:long) %></p>

  <% if @lease %>
    <p>
      <strong>Lease:</strong>
      <%= property_link(@lease.property_id) %>
      &middot;
      <%= applicant_link(@lease.applicant_id) %>
      &middot;
      <%= @lease.name %>
    </p>
  <% end %>
</div>

<div class="no-print">
  <% unless @transaction.paid? %>
    <%= form_with url: mark_paid_transaction_path(@transaction.id), method: :post do |f| %>
      <p>
        <label for="paid_on">Paid on</label>
        <%= f.date_field :paid_on, value: Date.current.iso8601, id: "paid_on", required: true %>
      </p>
      <%= f.submit "Mark paid" %>
    <% end %>
  <% end %>

  <p>
    <%= button_to "Print", "javascript:window.print()", method: :get, class: "outline" %>
    <%= link_to "← All transactions", transactions_path %>
  </p>
</div>
