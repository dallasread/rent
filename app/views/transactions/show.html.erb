<%
  property  = @lease ? Property.call(property_id: @lease.property_id).property : nil
  applicant = @lease ? Applicant.call(applicant_id: @lease.applicant_id).application : nil
%>

<div class="no-print">
  <%= breadcrumbs(
    [ "Properties", properties_path ],
    property  ? [ property_admin_label(property),  property_public_path(property.slug) ] : [ "(deleted property)" ],
    applicant ? [ applicant.name,                 applicant_path(applicant.id) ] : [ "(deleted applicant)" ],
    @lease    ? [ @lease.name, lease_path(@lease.id) ] : [ "(deleted lease)" ],
    [ @transaction.description ]
  ) %>
</div>

<header class="page-header no-print">
  <div>
    <span class="eyebrow">Transaction · <%= @transaction.id.first(8) %></span>
    <h1>
      Receipt
      <% if @transaction.archived? %><span class="badge" data-variant="secondary">Archived</span><% end %>
      <%= transaction_status_label(@transaction) %>
    </h1>
  </div>
  <div class="toolbar">
    <%= button_to "Edit", edit_transaction_path(@transaction.id), method: :get, class: "outline" %>
    <% if @transaction.archived? %>
      <%= button_to "Unarchive", unarchive_transaction_path(@transaction.id), method: :post, class: "outline" %>
    <% else %>
      <%= button_to "Archive", archive_transaction_path(@transaction.id), method: :post, class: "outline" %>
    <% end %>
    <%= button_to "Print", "javascript:window.print()", method: :get, class: "outline" %>
    <%= link_to "History", audit_path(entity_id: @transaction.id), class: "button ghost" %>
  </div>
</header>

<section class="card receipt">
  <div class="metric mb-6">
    <span class="eyebrow"><%= @transaction.kind %></span>
    <span class="figure"><%= format_money_cents(@transaction.amount_cents) %></span>
    <span class="caption"><%= @transaction.description %></span>
  </div>

  <dl class="kv">
    <dt>Method</dt>
    <dd><%= @transaction.method.presence || "—" %></dd>

    <% if @transaction.paid? %>
      <dt>Paid on</dt>
      <dd><%= @transaction.paid_at.to_date %></dd>
    <% end %>

    <dt>Recorded</dt>
    <dd><%= datetime_with_tooltip(@transaction.recorded_at, format: :long) %></dd>

    <% if @lease %>
      <dt>Lease</dt>
      <dd>
        <%= property_link(@lease.property_id) %>
        &middot;
        <%= applicant_link(@lease.applicant_id) %>
      </dd>
    <% end %>
  </dl>
</section>

<% unless @transaction.paid? %>
  <header class="section-head no-print">
    <h2>Mark paid</h2>
  </header>
  <section class="card no-print">
    <%= form_with url: mark_paid_transaction_path(@transaction.id), method: :post do |f| %>
      <div data-field>
        <label for="paid_on">Paid on</label>
        <%= f.date_field :paid_on, value: Date.current.iso8601, id: "paid_on", required: true %>
      </div>
      <div class="toolbar">
        <%= f.submit "Mark paid" %>
      </div>
    <% end %>
  </section>
<% end %>
