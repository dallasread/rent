<header class="page-header">
  <div>
    <span class="eyebrow">Operations</span>
    <h1>Transactions</h1>
  </div>
</header>

<div class="filter-bar">
  <span class="scope">
    <% if @show_archived %>
      <%= link_to "Active", transactions_path %>
      <strong>Archived</strong>
    <% else %>
      <strong>Active</strong>
      <%= link_to "Archived", transactions_path(archived: 1) %>
    <% end %>
  </span>
</div>

<% if @result.transactions.empty? %>
  <p class="empty">No transactions yet.</p>
<% else %>
  <div class="table">
    <table>
      <thead>
        <tr>
          <th>Description</th>
          <th>Kind</th>
          <th>Lease (property)</th>
          <th class="num">Amount</th>
          <th>Method</th>
          <th>Recorded</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @result.transactions.each do |t| %>
          <% lease = Lease.call(lease_id: t.lease_id).lease %>
          <tr>
            <td><%= link_to t.description, transaction_path(t.id) %></td>
            <td><%= t.kind %></td>
            <td>
              <%= lease ? property_link(lease.property_id) : "(deleted lease)" %>
              <% if lease&.archived? %><span class="badge" data-variant="secondary">Archived lease</span><% end %>
            </td>
            <td class="num"><%= format_money_cents(t.amount_cents) %></td>
            <td><%= t.method %></td>
            <td><%= link_to datetime_with_tooltip(t.recorded_at), transaction_path(t.id) %></td>
            <td><%= transaction_status_label(t) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
