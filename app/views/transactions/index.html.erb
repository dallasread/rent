<h1>Transactions</h1>

<% if @result.transactions.empty? %>
  <p>No transactions yet.</p>
<% else %>
  <table>
    <thead>
      <tr>
        <th>Recorded</th>
        <th>Lease (property)</th>
        <th>Description</th>
        <th>Amount</th>
        <th>Method</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% @result.transactions.each do |t| %>
        <% lease = Lease.call(lease_id: t.lease_id).lease %>
        <tr>
          <td><%= link_to t.recorded_at&.to_fs(:short), transaction_path(t.id) %></td>
          <td><%= lease ? property_link(lease.property_id) : "(deleted lease)" %></td>
          <td><%= link_to t.description, transaction_path(t.id) %></td>
          <td><%= format_money_cents(t.amount_cents) %></td>
          <td><%= t.method %></td>
          <td><%= transaction_status_label(t) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
