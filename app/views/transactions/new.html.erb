<%
  property  = Property.call(property_id: @lease.property_id).property
  applicant = Applicant.call(applicant_id: @lease.applicant_id).application
%>
<%= breadcrumbs(
  [ "Properties", properties_path ],
  property  ? [ property_admin_label(property),  property_path(property.slug) ] : [ "(deleted property)" ],
  applicant ? [ applicant.name,                 applicant_path(applicant.id) ] : [ "(deleted applicant)" ],
  [ @lease.name, lease_path(@lease.id) ],
  [ "New transaction" ]
) %>

<h1>Record transaction</h1>

<%= form_with url: transactions_path, method: :post do |f| %>
  <%= hidden_field_tag :lease_id, @lease.id %>

  <p>
    <label for="description">Description</label>
    <%= f.text_field :description, value: @form.description, id: "description", required: true, autofocus: true, placeholder: "e.g. January 2026 rent" %>
  </p>

  <p>
    <label for="amount">Amount</label>
    <%= f.number_field :amount, value: @form.amount, id: "amount", step: "0.01", min: "0", required: true %>
  </p>

  <p>
    <label for="method">Method</label>
    <%= f.select :method, RecordTransaction::METHODS, { selected: @form.method }, id: "method", required: true %>
  </p>

  <p>
    <label for="paid_on">Paid on</label>
    <%= f.date_field :paid_on, value: @form.paid_on, id: "paid_on" %>
    <small>Leave blank if not yet paid.</small>
  </p>

  <%= f.submit "Record" %>
  <%= link_to "Cancel", lease_path(@lease.id) %>
<% end %>
