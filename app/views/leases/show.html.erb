<%
  property = Property.call(property_id: @lease.property_id).property
  applicant = Applicant.call(applicant_id: @lease.applicant_id).application
%>

<%= breadcrumbs(
  [ "Properties", properties_path ],
  property ? [ property_admin_label(property), property_public_path(property.slug) ] : [ "(deleted property)" ],
  applicant ? [ applicant.name, applicant_path(applicant.id) ] : [ "(deleted applicant)" ],
  [ @lease.name ]
) %>

<h1>Lease <% if @lease.archived? %><span class="badge badge-muted">Archived</span><% end %></h1>

<p><strong>Property:</strong> <%= property_link(@lease.property_id) %></p>
<p><strong>Tenant:</strong> <%= applicant_link(@lease.applicant_id) %>
  <% if (m = applicant_mobile(@lease.applicant_id)) %>
    (<%= link_to m, "tel:#{m}" %>)
  <% end %>
</p>
<p><strong>Rent:</strong> <%= format_money_cents(@lease.rent_cents) %> <%= @lease.frequency %></p>
<p><strong>Start:</strong> <%= @lease.start_date %></p>
<p><strong>End:</strong> <%= @lease.end_date || "open" %></p>

<p>
  <%= button_to "Edit lease", edit_lease_path(@lease.id), method: :get %>
  <% if @lease.archived? %>
    <%= button_to "Unarchive", unarchive_lease_path(@lease.id), method: :post %>
  <% else %>
    <%= button_to "Archive", archive_lease_path(@lease.id), method: :post %>
  <% end %>
  <%= link_to "History", audit_path(entity_id: @lease.id) %>
</p>

<h2>Transactions</h2>

<p><%= button_to "Record transaction", new_lease_transaction_path(@lease.id), method: :get %></p>

<% txs = Transactions.call(lease_id: @lease.id).transactions %>
<% if txs.empty? %>
  <p>No transactions yet.</p>
<% else %>
  <table>
    <thead>
      <tr>
        <th>Description</th>
        <th>Kind</th>
        <th>Amount</th>
        <th>Method</th>
        <th>Recorded</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% txs.each do |t| %>
        <tr>
          <td><%= link_to t.description, transaction_path(t.id) %></td>
          <td><%= t.kind %></td>
          <td><%= format_money_cents(t.amount_cents) %></td>
          <td><%= t.method %></td>
          <td><%= link_to t.recorded_at&.to_fs(:short), transaction_path(t.id) %></td>
          <td><%= transaction_status_label(t) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<p><%= link_to "← All leases", leases_path %></p>
