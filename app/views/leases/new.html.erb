<%
  property = @applicant.property_id ? Property.call(property_id: @applicant.property_id).property : nil
%>
<%= breadcrumbs(
  *(property ? [ [ "Properties", properties_path ], [ property_admin_label(property), property_public_path(property.slug) ] ] : [ [ "Applicants", applicants_path ] ]),
  [ @applicant.name, applicant_path(@applicant.id) ],
  [ "New lease" ]
) %>

<h1>Create lease</h1>

<p>Tenant: <strong><%= @applicant.name %></strong> (<%= @applicant.mobile %>)</p>

<%= form_with url: leases_path, method: :post do |f| %>
  <%= hidden_field_tag :applicant_id, @applicant.id %>

  <p>
    <label for="property_id">Property</label>
    <%= f.select :property_id,
        @properties.map { |p| [ property_admin_label(p), p.id ] },
        { include_blank: "— Select a property —", selected: @form.property_id },
        id: "property_id", required: true %>
  </p>

  <p>
    <label for="rent">Rent</label>
    <%= f.number_field :rent, value: @form.rent, id: "rent", step: "0.01", min: "0", required: true %>
  </p>

  <p>
    <label for="frequency">Frequency</label>
    <%= f.select :frequency, CreateLease::FREQUENCIES, { selected: @form.frequency }, id: "frequency", required: true %>
  </p>

  <p>
    <label for="start_date">Start date</label>
    <%= f.date_field :start_date, value: @form.start_date, id: "start_date", required: true %>
  </p>

  <p>
    <label for="end_date">End date (optional)</label>
    <%= f.date_field :end_date, value: @form.end_date, id: "end_date" %>
  </p>

  <% if @taxes.any? %>
    <fieldset>
      <legend>Taxes</legend>
      <% @taxes.each do |t| %>
        <p>
          <label>
            <%= check_box_tag "tax_ids[]", t.id, @form.tax_ids.include?(t.id) %>
            <%= t.label %>
          </label>
        </p>
      <% end %>
    </fieldset>
  <% end %>

  <%= f.submit "Create lease" %>
  <%= link_to "Cancel", applicant_path(@applicant.id) %>
<% end %>
