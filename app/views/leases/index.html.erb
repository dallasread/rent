<header class="page-header">
  <div>
    <span class="eyebrow">Operations</span>
    <h1>Leases</h1>
  </div>
</header>

<div class="filter-bar">
  <span class="scope">
    <% [["current", "Current"], ["inactive", "Inactive"], ["archived", "Archived"]].each do |s, label| %>
      <% if @scope.to_s == s %>
        <strong><%= label %></strong>
      <% else %>
        <%= link_to label, leases_path(scope: s) %>
      <% end %>
    <% end %>
  </span>
</div>

<% if @rent_roll.entries.empty? %>
  <p class="empty">No <%= @scope %> leases.</p>
<% else %>
  <div class="table">
    <table>
      <thead>
        <tr>
          <th>Lease</th>
          <th>Property</th>
          <th>Tenant</th>
          <th class="num">Rent</th>
          <th>Frequency</th>
          <th>Paid through</th>
          <th>Next due</th>
          <th>Status</th>
          <th class="actions">Action</th>
        </tr>
      </thead>
      <tbody>
        <% @rent_roll.entries.each do |e| %>
          <tr>
            <td><%= link_to e.lease.name, lease_path(e.lease.id) %></td>
            <td><%= property_link(e.lease.property_id) %></td>
            <td><%= tenant_link(e.lease.applicant_id) %></td>
            <td class="num"><%= format_money_cents(e.total_cents) %></td>
            <td><%= e.lease.frequency %></td>
            <td><%= e.paid_through || "—" %></td>
            <td><%= e.next_due_on || "—" %></td>
            <td>
              <% if e.lease.archived? %>
                <span class="badge" data-variant="secondary">Archived</span>
              <% elsif e.lease.start_date > @rent_roll.as_of %>
                <span class="badge" data-variant="secondary">Upcoming</span>
              <% elsif e.lease.end_date && e.lease.end_date < @rent_roll.as_of %>
                <span class="badge" data-variant="secondary">Ended</span>
              <% elsif e.overdue? %>
                <span class="badge" data-variant="danger">Due now</span>
              <% else %>
                <span class="badge outline">Upcoming</span>
              <% end %>
            </td>
            <td class="actions">
              <% if e.next_due_on %>
                <%= button_to "Record rent", record_rent_roll_path(e.lease.id), method: :post, class: "outline small" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
