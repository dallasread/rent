<h1>Leases</h1>

<% if @result.leases.empty? %>
  <p>No leases yet.</p>
<% else %>
  <table>
    <thead>
      <tr>
        <th>Property</th>
        <th>Tenant</th>
        <th>Start</th>
        <th>End</th>
      </tr>
    </thead>
    <tbody>
      <% @result.leases.each do |l| %>
        <tr>
          <td><%= property_link(l.property_id) %></td>
          <td><%= link_to applicant_name(l.applicant_id), lease_path(l.id) %></td>
          <td><%= l.start_date %></td>
          <td><%= l.end_date || "open" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
