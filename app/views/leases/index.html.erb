<h1>Leases</h1>

<p>
  <% if @show_archived %>
    <%= link_to "Active", leases_path %> · <strong>Archived</strong>
  <% else %>
    <strong>Active</strong> · <%= link_to "Archived", leases_path(archived: 1) %>
  <% end %>
</p>

<% if @rent_roll.entries.empty? %>
  <p>No <%= @show_archived ? "archived" : "active" %> leases.</p>
<% else %>
  <table>
    <thead>
      <tr>
        <th>Property</th>
        <th>Tenant</th>
        <th>Rent</th>
        <th>Frequency</th>
        <th>Paid through</th>
        <th>Next due</th>
        <th>Status</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% @rent_roll.entries.each do |e| %>
        <tr>
          <td><%= property_link(e.lease.property_id) %></td>
          <td><%= link_to applicant_name(e.lease.applicant_id), lease_path(e.lease.id) %></td>
          <td><%= format_money_cents(e.total_cents) %></td>
          <td><%= e.lease.frequency %></td>
          <td><%= e.paid_through || "—" %></td>
          <td><%= e.next_due_on || "—" %></td>
          <td>
            <% if e.lease.archived? %>
              <span class="badge badge-muted">Archived</span>
            <% elsif e.lease.start_date > @rent_roll.as_of %>
              <span class="badge badge-muted">Upcoming</span>
            <% elsif e.lease.end_date && e.lease.end_date < @rent_roll.as_of %>
              <span class="badge badge-muted">Ended</span>
            <% elsif e.overdue? %>
              <span class="badge badge-overdue">Due now</span>
            <% else %>
              <span class="badge badge-muted">Upcoming</span>
            <% end %>
          </td>
          <td>
            <% if e.next_due_on %>
              <%= button_to "Record rent", record_rent_roll_path(e.lease.id), method: :post %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
