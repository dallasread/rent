<h1>Rent roll</h1>

<p><small>Active leases as of <%= @result.as_of %>.</small></p>

<% if @result.entries.empty? %>
  <p>No active leases.</p>
<% else %>
  <table>
    <thead>
      <tr>
        <th>Property</th>
        <th>Tenant</th>
        <th>Rent</th>
        <th>Frequency</th>
        <th>Paid through</th>
        <th>Next due</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% @result.entries.each do |e| %>
        <tr>
          <td><%= property_link(e.lease.property_id) %></td>
          <td><%= link_to applicant_name(e.lease.applicant_id), lease_path(e.lease.id) %></td>
          <td><%= format_money_cents(e.lease.rent_cents) %></td>
          <td><%= e.lease.frequency %></td>
          <td><%= e.paid_through || "—" %></td>
          <td><%= e.next_due_on %></td>
          <td>
            <% if e.overdue? %>
              <span class="badge badge-overdue">Due now</span>
            <% else %>
              <span class="badge badge-muted">Upcoming</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
