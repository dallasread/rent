<header class="page-header">
  <div>
    <span class="eyebrow">System</span>
    <h1>API tokens</h1>
  </div>
  <div class="toolbar">
    <%= link_to "API docs", api_docs_path, class: "button ghost" %>
    <%= link_to "New token", new_api_token_path, class: "button" %>
  </div>
</header>

<% if @just_created %>
  <div class="flash flash-notice">
    <p><strong>Token <%= @just_created.name %> created.</strong> Copy it now — we display it once for convenience but treat it as the secret it is.</p>
    <p><code><%= @just_created.token %></code></p>
  </div>
<% end %>

<% active = @result.api_tokens.reject(&:revoked?) %>
<% revoked = @result.api_tokens.select(&:revoked?) %>

<% if active.empty? && revoked.empty? %>
  <p class="empty">No tokens yet.</p>
<% else %>
  <header class="section-head">
    <h2>Active</h2>
  </header>
  <% if active.empty? %>
    <p class="empty">None.</p>
  <% else %>
    <div class="table">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Token</th>
            <th>Created</th>
            <th class="actions">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% active.each do |t| %>
            <tr>
              <td><%= t.name %></td>
              <td><code><%= t.masked %></code></td>
              <td><%= datetime_with_tooltip(t.created_at) %></td>
              <td class="actions">
                <div class="toolbar small">
                  <%= button_to "Revoke", api_token_path(t.id), method: :delete, class: "outline small", data: { variant: "danger", turbo_confirm: "Revoke #{t.name}?" } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <% if revoked.any? %>
    <header class="section-head">
      <h2>Revoked</h2>
    </header>
    <div class="table">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Created</th>
            <th>Revoked</th>
          </tr>
        </thead>
        <tbody>
          <% revoked.each do |t| %>
            <tr>
              <td><%= t.name %></td>
              <td><%= datetime_with_tooltip(t.created_at) %></td>
              <td><%= datetime_with_tooltip(t.revoked_at) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% end %>
