<h1>Taxes</h1>

<p><%= link_to "New tax", new_tax_path %></p>

<% if @result.taxes.empty? %>
  <p>No taxes defined. Add one and it'll be available as a checkbox when creating or editing a lease.</p>
<% else %>
  <table>
    <thead>
      <tr><th>Name</th><th>Rate</th><th></th></tr>
    </thead>
    <tbody>
      <% @result.taxes.each do |t| %>
        <tr>
          <td><%= link_to t.name, edit_tax_path(t.id) %></td>
          <td><%= format("%g", t.rate_percent) %>%</td>
          <td><%= button_to "Edit", edit_tax_path(t.id), method: :get %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
