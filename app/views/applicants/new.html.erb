<%= breadcrumbs(
  [ "Applicants", applicants_path ],
  [ "Add" ]
) %>

<h1>Add applicant</h1>

<%= form_with url: applicants_path, method: :post do |f| %>
  <p>
    <label for="name">Name</label>
    <%= f.text_field :name, value: @form.name, id: "name", required: true, autofocus: true %>
  </p>

  <p>
    <label for="mobile">Mobile</label>
    <%= f.telephone_field :mobile, value: @form.mobile, id: "mobile", required: true %>
  </p>

  <p>
    <label for="property_id">Property (optional)</label>
    <%= f.select :property_id,
        @properties.map { |p| [ property_admin_label(p), p.id ] },
        { include_blank: "— No specific property —" },
        id: "property_id" %>
  </p>

  <p>
    <label for="summary">Summary</label><br>
    <%= f.text_area :summary, value: @form.summary, id: "summary", rows: 6, cols: 60, required: true %>
  </p>

  <%= f.submit "Add applicant" %>
  <%= link_to "Cancel", applicants_path %>
<% end %>
