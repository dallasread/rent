<% if @application.property_id %>
  <%= breadcrumbs(
    [ "Properties", properties_path ],
    [ property_name(@application.property_id), property_public_path(Property.call(property_id: @application.property_id).property&.slug) ],
    [ @application.name ]
  ) %>
<% else %>
  <%= breadcrumbs(
    [ "Applicants", applicants_path ],
    [ @application.name ]
  ) %>
<% end %>

<h1><%= @application.name %> <% if @application.archived? %><span class="badge badge-muted">Archived</span><% end %></h1>

<p>
  <strong>Applied for:</strong>
  <% if @application.property_id.nil? %>
    <em>No specific property (adhoc)</em>
  <% else %>
    <%= property_link(@application.property_id) %>
  <% end %>
</p>

<p><strong>Mobile:</strong> <%= link_to @application.mobile, "tel:#{@application.mobile}" %></p>
<p><strong>Submitted:</strong> <%= datetime_with_tooltip(@application.submitted_at, format: :long) %></p>

<h2>Summary</h2>
<%= simple_format @application.summary %>

<p>
  <%= button_to "Create lease", new_applicant_lease_path(@application.id), method: :get %>
  <% if @application.archived? %>
    <%= button_to "Unarchive", unarchive_applicant_path(@application.id), method: :post %>
  <% else %>
    <%= button_to "Archive", archive_applicant_path(@application.id), method: :post %>
  <% end %>
  <%= link_to "History", audit_path(entity_id: @application.id) %>
  <%= link_to "← All applicants", applicants_path %>
</p>
