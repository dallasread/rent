<% if @application.property_id %>
  <%= breadcrumbs(
    [ "Properties", properties_path ],
    [ property_name(@application.property_id), property_public_path(Property.call(property_id: @application.property_id).property&.slug) ],
    [ @application.name ]
  ) %>
<% else %>
  <%= breadcrumbs(
    [ "Applicants", applicants_path ],
    [ @application.name ]
  ) %>
<% end %>

<header class="page-header">
  <div>
    <span class="eyebrow">Applicant</span>
    <h1>
      <%= @application.name %>
      <% if @application.archived? %><span class="badge" data-variant="secondary">Archived</span><% end %>
    </h1>
  </div>
  <div class="toolbar">
    <%= button_to "Create lease", new_applicant_lease_path(@application.id), method: :get %>
    <% if @application.archived? %>
      <%= button_to "Unarchive", unarchive_applicant_path(@application.id), method: :post, class: "outline" %>
    <% else %>
      <%= button_to "Archive", archive_applicant_path(@application.id), method: :post, class: "outline" %>
    <% end %>
    <%= link_to "History", audit_path(entity_id: @application.id), class: "button ghost" %>
  </div>
</header>

<section class="card">
  <dl class="kv">
    <dt>Applied for</dt>
    <dd>
      <% if @application.property_id.nil? %>
        <em>No specific property (adhoc)</em>
      <% else %>
        <%= property_link(@application.property_id) %>
      <% end %>
    </dd>

    <dt>Mobile</dt>
    <dd><%= link_to @application.mobile, "tel:#{@application.mobile}" %></dd>

    <dt>Submitted</dt>
    <dd><%= datetime_with_tooltip(@application.submitted_at, format: :long) %></dd>
  </dl>
</section>

<header class="section-head">
  <h2>Summary</h2>
</header>
<%= simple_format @application.summary %>
