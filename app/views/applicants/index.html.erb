<h1>Applicants</h1>

<% if @result.applications.empty? %>
  <p>No applications yet.</p>
<% else %>
  <table>
    <thead>
      <tr>
        <th>Submitted</th>
        <th>Property</th>
        <th>Name</th>
        <th>Mobile</th>
        <th>Summary</th>
      </tr>
    </thead>
    <tbody>
      <% @result.applications.each do |a| %>
        <tr>
          <td><%= a.submitted_at&.to_fs(:short) %></td>
          <td><%= a.property_slug ? link_to(a.property_name, property_path(a.property_slug)) : a.property_name %></td>
          <td><%= a.name %></td>
          <td><%= a.mobile %></td>
          <td><%= simple_format a.summary %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
