<h1>Applicants</h1>

<p>
  <%= link_to "Add applicant", new_applicant_path %>
  &middot;
  <% if @show_archived %>
    Showing archived. <%= link_to "Hide archived", applicants_path %>
  <% else %>
    <%= link_to "Show archived", applicants_path(archived: 1) %>
  <% end %>
</p>

<% if @result.applications.empty? %>
  <p>No applications yet.</p>
<% else %>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Property</th>
        <th>Mobile</th>
        <th>Submitted</th>
        <th>Summary</th>
      </tr>
    </thead>
    <tbody>
      <% @result.applications.each do |a| %>
        <tr>
          <td><%= link_to a.name, applicant_path(a.id) %></td>
          <td>
            <% if a.property_id.nil? %>
              <em>(adhoc)</em>
            <% else %>
              <%= property_link(a.property_id) %>
            <% end %>
          </td>
          <td><%= link_to a.mobile, "tel:#{a.mobile}" %></td>
          <td><%= datetime_with_tooltip(a.submitted_at) %></td>
          <td><%= truncate(a.summary.to_s, length: 80) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
