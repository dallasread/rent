<h1>Applicants</h1>

<p><%= link_to "Add applicant", new_applicant_path %></p>

<% if @result.applications.empty? %>
  <p>No applications yet.</p>
<% else %>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Property</th>
        <th>Mobile</th>
        <th>Submitted</th>
        <th>Summary</th>
      </tr>
    </thead>
    <tbody>
      <% @result.applications.each do |a| %>
        <tr>
          <td><%= link_to a.name, applicant_path(a.id) %></td>
          <td>
            <% if a.property_id.nil? %>
              <em>(adhoc)</em>
            <% else %>
              <%= property_link(a.property_id) %>
            <% end %>
          </td>
          <td><%= link_to a.mobile, "tel:#{a.mobile}" %></td>
          <td><%= a.submitted_at&.to_fs(:short) %></td>
          <td><%= truncate(a.summary.to_s, length: 80) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
